{
  "name": "@pallattu/aeg-intent-gate",
  "version": "0.5.2",
  "description": "A tiny TypeScript approval gate for AI tool calls, MCP tools, and human-in-the-loop workflows.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aeg-intent-gate": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacob-git/aeg-intent-gate.git"
  },
  "homepage": "https://aeg-intent-gate.pages.dev",
  "bugs": {
    "url": "https://github.com/jacob-git/aeg-intent-gate/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "ai-agent",
    "ai-safety",
    "llm",
    "mcp",
    "model-context-protocol",
    "tool-calling",
    "tool-calls",
    "human-in-the-loop",
    "approval",
    "guardrails",
    "approval-gate",
    "intent-gate",
    "openai",
    "anthropic",
    "intent",
    "policy",
    "governance",
    "capabilities",
    "authorization",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "demo": "npm run build && node dist/cli.js",
    "site:serve": "npx wrangler pages dev site",
    "site:deploy": "npx wrangler pages deploy site --project-name aeg-intent-gate",
    "example": "npm run build && node examples/basic-lifecycle.mjs",
    "example:tool-call": "npm run build && node examples/tool-call-approval.mjs",
    "example:openai": "npm run build && node examples/openai-tool-call-firewall.mjs",
    "example:anthropic": "npm run build && node examples/anthropic-tool-use-firewall.mjs",
    "example:mcp": "npm run build && node examples/mcp-tool-gate.mjs",
    "example:approval-server": "npm run build && node examples/approval-server.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "prepublishOnly": "npm test"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "typescript": "^5.4.0"
  }
}
